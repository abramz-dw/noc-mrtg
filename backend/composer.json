  "type": "project",
  "license": "MIT",
  "authors": [
    {
      "name": "NOC Team",
      "email": "admin@noc.local"
    }
  ],
  "require": {
    "php": "^8.3",
    "nikic/fast-route": "^1.3",
    "php-di/php-di": "^7.0",
    "monolog/monolog": "^3.6",
    "vlucas/phpdotenv": "^5.6",
    "firebase/php-jwt": "^7.0"
  },
  "autoload": {
    "psr-4": {
      "App\\": "src/"
    }
  },
  "scripts": {
