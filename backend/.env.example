# ============================================================================
# NOC Web Management System - Backend Configuration
# ============================================================================

# Application
APP_NAME="NOC Web Management"
APP_ENV=production
APP_DEBUG=false
APP_TIMEZONE=Asia/Jakarta
SERVER_NAME=10.123.123.205

# Directories
FRONTEND_URL=http://10.123.123.205:8080
FRONTEND_DIR=/var/www/noc-mgt/frontend
BACKEND_URL=http://10.123.123.205:8081
BACKEND_DIR=/var/www/noc-mgt/backend

# Database Configuration
DB_HOST=localhost
DB_PORT=3306
DB_NAME=noc_management
DB_USER=noc_user
DB_PASS=ChangeThisToSecurePassword
DB_CHARSET=utf8mb4
DB_TIMEZONE=+07:00

# JWT Configuration
JWT_SECRET=ChangeThisToLongRandomSecretKey1234567890abcdefghijklmnopqrstuvwxyzABCDEFGHIJKLMNOPQRSTUVWXYZ
JWT_ALGORITHM=HS256
JWT_EXPIRATION=86400

# Logging
LOG_DIR=/var/log/apps
LOG_LEVEL=info

# CORS
CORS_ORIGIN=http://10.123.123.205:8080

# Prometheus
PROMETHEUS_URL=http://10.123.123.205:9090
PROMETHEUS_PUSHGATEWAY=http://10.123.123.205:9091

# SNMP Defaults
SNMP_COMMUNITY=public
SNMP_TIMEOUT=5
SNMP_RETRIES=3
SNMP_VERSION=2c

# Rate Limiting
RATE_LIMIT_ENABLED=true
RATE_LIMIT_REQUESTS_PER_MINUTE=100

# Session
SESSION_TIMEOUT=3600
SESSION_COOKIE_SECURE=true
SESSION_COOKIE_HTTPONLY=true
